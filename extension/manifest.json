{
  "manifest_version": 3,
  "name": "Elens",
  "version": "0.0.1",
  "description": "Elens inspector for Chrome pages",
  "permissions": ["windows", "activeTab", "tabs"],
  "action": {
    "default_title": "Toggle Elens inspector"
  },
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js", "inspector.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
