{
  "manifest_version": 3,
  "name": "Elens Window Controller",
  "version": "0.0.1",
  "description": "Allow Elens to resize and reposition the current browser window.",
  "permissions": ["windows"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
